    "react-dom": "18.3.1",
    "react-use": "17.6.1",
    "rxjs": "7.8.2",
    "semver": "7.8.5"
  },
  "devDependencies": {
    "@babel/core": "7.29.6",
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "9.39.5",
    "@grafana/eslint-config": "10.0.0",
    "@grafana/plugin-e2e": "3.10.0",
