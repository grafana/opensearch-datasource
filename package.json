{
  "name": "grafana-opensearch-datasource",
  "version": "2.34.0",
  "private": true,
  "description": "",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e": "playwright test",
    "generate-release-notes": "PREV_TAG=$(git tag --sort=-v:refname | head -n 1) && gh api --method POST /repos/grafana/opensearch-datasource/releases/generate-notes -f tag_name=v${npm_package_version} -f target_commitish=main -f previous_tag_name=${PREV_TAG} | jq -r .body",
    "lint": "eslint --cache .",
    "lint:fix": "yarn run lint --fix",
    "server": "docker compose up --build",
    "sign": "npx --yes --ignore-scripts --package @grafana/sign-plugin@3.2.2 -- sign-plugin",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "test:coverage": "jest --coverage",
    "test:coverage:changes": "jest --coverage --changedSince=origin/main",
    "typecheck": "tsc --noEmit"
  },
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/aws-sdk": "0.12.0",
